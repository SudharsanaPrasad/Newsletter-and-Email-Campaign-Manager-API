{
  "info": {
    "name": "Newsletter and Email Campaign Manager API",
    "description": "Postman collection for the newsletter API. Set baseUrl, then run Register or Login to fill the token automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.token) {",
                  "    pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Mailing Lists",
      "item": [
        {
          "name": "Create mailing list",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weekly Newsletter\"\n}"
            }
          }
        },
        {
          "name": "Get my mailing lists",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists"
              ]
            }
          }
        },
        {
          "name": "Get mailing list by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists",
                "1"
              ]
            }
          }
        },
        {
          "name": "Update mailing list",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists",
                "1"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Monthly Newsletter\"\n}"
            }
          }
        },
        {
          "name": "Add subscriber",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists/1/subscribers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists",
                "1",
                "subscribers"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\"\n}"
            }
          }
        },
        {
          "name": "Remove subscriber",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists/1/subscribers/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists",
                "1",
                "subscribers",
                "1"
              ]
            }
          }
        },
        {
          "name": "Delete mailing list",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mailing-lists/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mailing-lists",
                "1"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "Create campaign (draft)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Sale\",\n  \"subject\": \"Our biggest sale is here\",\n  \"content\": \"Hello, do not miss our spring sale.\",\n  \"mailingListId\": 1\n}"
            }
          }
        },
        {
          "name": "Create campaign (scheduled)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Product Launch\",\n  \"subject\": \"Something new is coming\",\n  \"content\": \"We are launching soon.\",\n  \"mailingListId\": 1,\n  \"status\": \"SCHEDULED\",\n  \"scheduledTime\": \"2026-12-31T10:00:00\"\n}"
            }
          }
        },
        {
          "name": "Get my campaigns (paged)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Filter campaigns by status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns?status=SCHEDULED",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "SCHEDULED"
                }
              ]
            }
          }
        },
        {
          "name": "Get campaign by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns",
                "1"
              ]
            }
          }
        },
        {
          "name": "Update campaign",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns",
                "1"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Sale (updated)\",\n  \"subject\": \"Extended: our spring sale\",\n  \"content\": \"Good news, the sale is extended.\",\n  \"mailingListId\": 1\n}"
            }
          }
        },
        {
          "name": "Schedule campaign",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns/1/schedule",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns",
                "1",
                "schedule"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduledTime\": \"2026-12-31T10:00:00\"\n}"
            }
          }
        },
        {
          "name": "Campaign send logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns/1/logs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns",
                "1",
                "logs"
              ]
            }
          }
        },
        {
          "name": "Delete campaign",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/campaigns/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "campaigns",
                "1"
              ]
            }
          }
        }
      ]
    }
  ]
}
