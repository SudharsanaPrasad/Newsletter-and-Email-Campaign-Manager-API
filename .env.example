# Deployment / local run configuration - set these as environment variables.
# On Render set them in the dashboard. Never commit real values.

# JDBC URL. PostgreSQL in production, or MySQL locally. Examples:
#   postgres: jdbc:postgresql://HOST:5432/DBNAME
#   mysql:    jdbc:mysql://localhost:3306/newsletter_db?createDatabaseIfNotExist=true
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DBNAME
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# a long random secret (at least 32 characters) used to sign JWTs
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
